# Copy to `.env` or `.env.local` and fill in values. Never commit real secrets.
# See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# SQLite — must match the file the app opens (see src/lib/sqlite-path.ts)
# Default when unset: ./dev.db in project root
# start.sh also sets SQLITE_DATABASE_PATH to the resolved absolute path at boot.
DATABASE_URL=file:./dev.db

# Session signing — required in production (use a long random string)
AUTH_SECRET=

# Public site URL for auth redirects and cookies (set in production)
AUTH_URL=

# Optional: public URL for emails and client-visible absolute links
NEXT_PUBLIC_APP_URL=

# Google OAuth (optional if you only use email/password)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — transactional email (optional; verification emails skip if unset)
RESEND_API_KEY=

# Optional: comma-separated emails that always receive admin on sign-in (not stored in git)
AUTH_ADMIN_EMAILS=

# Buy Me a Coffee webhook signing secret (for supporter badge automation)
BMC_WEBHOOK_SECRET=

# Optional: comma-separated hostnames allowed when reading X-Forwarded-Host
TRUSTED_HOSTS=

# Optional: stable Server Action encryption across deploys (generate once: openssl rand -base64 32)
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Player Sync — Warframe Arsenal Twitch extension auth (server-side only)
# Install https://www.warframe.com/en/twitch-extension on YOUR Twitch channel, then set
# its numeric channel ID (Creator Dashboard → Settings → Channel → About, or Helix users API).
# TWITCH_ARSENAL_CHANNEL_ID=
# Optional override: paste a fresh extension JWT instead of resolving via channel ID
# WARFRAME_ARSENAL_JWT=
