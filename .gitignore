# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.kate-swp
tmp-wiki*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets (example file is allowed)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# database
*.db
*.db-journal

# user uploads
public/uploads/

# Python
__pycache__/
*.py[cod]
*$py.class

# Cursor IDE local config / rules (do not commit)
.cursor/

# Personal / local notes (not project docs)
docs/warframe-msi-a17-keybinds.md

# Local script scratch / dumps (do not commit)
scripts/**/__pycache__/
scripts/*.log
scripts/**/*.log
scripts/**/*.wikitext
scripts/_wiki_incarnon/
scripts/_tmp_*/
scripts/_live-og.png
scripts/_arcane_inventory.txt
scripts/_archgun_wiki.json
scripts/_white_mod_stems*.txt
scripts/_wiki_verify.txt
scripts/_upgrade_mod_cards.log
scripts/arcane_audit_report.txt
scripts/arcane_rank_verify.txt
scripts/arcane_wiki_verify.txt
scripts/*_verify.txt
scripts/*_audit_report.txt
