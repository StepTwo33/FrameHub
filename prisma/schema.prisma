// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  passwordHash  String?
  role          String    @default("user") // user | moderator | admin
  bannedAt      DateTime?
  banReason     String?
  supporterAt   DateTime?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  builds        Build[]
  buildVotes    BuildVote[]
  reports       Report[]
  donationEvents DonationEvent[]
  siteUpdates   SiteUpdate[]
  dataOverrides DataOverride[]
}

model DonationEvent {
  id             String   @id @default(cuid())
  externalId     String   @unique
  provider       String   @default("buymeacoffee")
  supporterEmail String
  userId         String?
  amount         String?
  eventType      String
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([supporterEmail])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Report {
  id               String   @id @default(cuid())
  userId           String?
  reporterName     String   @default("Anonymous")
  itemType         String   // weapon | mod | warframe | companion | archon_shard | other
  itemName         String
  itemId           String   @default("")
  issues           String   // JSON string of issue flags
  statDiscrepancies String  @default("[]") // JSON string
  comment          String   @default("")
  status           String   @default("open") // open | resolved | wontfix
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
}

model Build {
  id          String      @id @default(cuid())
  userId      String
  name        String
  description String      @default("")
  isPublic    Boolean     @default(false)
  type        String      // 'weapon' | 'warframe' | 'companion' | 'modular' | 'archwing' | 'railjack'
  itemId      String      @default("")
  upvoteCount Int         @default(0)
  data        String      // JSON string of build data
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes       BuildVote[]

  @@index([userId])
  @@index([userId, type])
  @@index([isPublic])
  @@index([isPublic, type, updatedAt])
  @@index([isPublic, type, upvoteCount])
  @@index([isPublic, itemId])
}

model BuildVote {
  id        String   @id @default(cuid())
  userId    String
  buildId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([userId, buildId])
  @@index([buildId])
}

/** Manual dev posts shown on the home page — not tied to GitHub activity. */
model SiteUpdate {
  id        String   @id @default(cuid())
  title     String
  body      String
  published Boolean  @default(true)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([published, createdAt])
}

/** Staff data fixes — shared globally; one override per target (type + id). */
model DataOverride {
  id         String   @id
  targetType String
  targetId   String
  action     String   // modify | add | remove
  fields     Json     @default("{}")
  note       String   @default("")
  authorId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([targetType, targetId])
  @@index([targetType])
}
