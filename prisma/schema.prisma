// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  passwordHash  String?
  role          String    @default("user") // user | moderator | admin
  bannedAt      DateTime?
  banReason     String?
  supporterAt   DateTime?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  builds        Build[]
  buildVotes    BuildVote[]
  reports       Report[]
  donationEvents DonationEvent[]
  siteUpdates   SiteUpdate[]
  dataOverrides DataOverride[]
  discordLink   DiscordUserLink?
}

// ── FrameHub Discord bot (worldstate alerts config) ───────────────────

model DiscordUserLink {
  id           String    @id @default(cuid())
  userId       String    @unique
  discordId    String    @unique
  username     String?
  discriminator String?
  avatar       String?
  accessToken  String?
  refreshToken String?
  tokenExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DiscordGuild {
  id          String   @id // Discord snowflake
  name        String
  icon        String?
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  config      DiscordGuildConfig?
  alertRoutes AlertRoute[]
}

model DiscordGuildConfig {
  id       String @id @default(cuid())
  guildId  String @unique
  platform String @default("pc") // pc | ps4 | xb1 | swi
  timezone String @default("UTC")
  guild    DiscordGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

/// When eventType fires, post to channelId (one row per guild+channel+event).
model AlertRoute {
  id            String  @id @default(cuid())
  guildId       String
  channelId     String
  eventType     String  // sortie | archon | arbitration | baro | cetus | vallis | …
  enabled       Boolean @default(true)
  mentionRoleId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  guild         DiscordGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId, eventType])
  @@index([guildId, eventType, enabled])
}

/// Last-seen fingerprints for worldstate transition detection (bot poller).
model WorldstateFingerprint {
  id          String   @id @default(cuid())
  platform    String
  eventType   String
  fingerprint String
  updatedAt   DateTime @updatedAt

  @@unique([platform, eventType])
}

model DonationEvent {
  id             String   @id @default(cuid())
  externalId     String   @unique
  provider       String   @default("buymeacoffee")
  supporterEmail String
  userId         String?
  amount         String?
  eventType      String
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([supporterEmail])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Report {
  id               String   @id @default(cuid())
  userId           String?
  reporterName     String   @default("Anonymous")
  itemType         String   // weapon | mod | warframe | companion | archon_shard | other
  itemName         String
  itemId           String   @default("")
  issues           String   // JSON string of issue flags
  statDiscrepancies String  @default("[]") // JSON string
  comment          String   @default("")
  status           String   @default("open") // open | resolved | wontfix
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
}

model Build {
  id          String      @id @default(cuid())
  userId      String
  name        String
  description String      @default("")
  isPublic    Boolean     @default(false)
  type        String      // 'weapon' | 'warframe' | 'companion' | 'modular' | 'archwing' | 'railjack'
  itemId      String      @default("")
  upvoteCount Int         @default(0)
  /** JSON string array of meta tags, e.g. ["steel_path","budget"]. */
  tags        String      @default("[]")
  data        String      // JSON string of build data
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes       BuildVote[]

  @@index([userId])
  @@index([userId, type])
  @@index([isPublic])
  @@index([isPublic, type, updatedAt])
  @@index([isPublic, type, upvoteCount])
  @@index([isPublic, itemId])
}

model BuildVote {
  id        String   @id @default(cuid())
  userId    String
  buildId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([userId, buildId])
  @@index([buildId])
}

/** Manual dev posts shown on the home page — not tied to GitHub activity. */
model SiteUpdate {
  id        String   @id @default(cuid())
  title     String
  body      String
  published Boolean  @default(true)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([published, createdAt])
}

/** Staff data fixes — shared globally; one override per target (type + id). */
model DataOverride {
  id         String   @id
  targetType String
  targetId   String
  action     String   // modify | add | remove
  fields     Json     @default("{}")
  note       String   @default("")
  authorId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([targetType, targetId])
  @@index([targetType])
}
